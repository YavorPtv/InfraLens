{
  "name": "infralens",
  "version": "0.1.0",
  "private": true,
  "description": "Developer-focused AWS architecture analyzer.",
  "workspaces": [
    "apps/*",
    "packages/*",
    "infra/*"
  ],
  "scripts": {
    "analyze": "npm run build --workspace @infralens/shared && npm run build --workspace @infralens/analyzer && npm run build --workspace @infralens/cli && node apps/cli/dist/index.js",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.9",
    "chai": "^4.5.0",
    "mocha": "^10.8.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
