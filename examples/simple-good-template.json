{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Safer CloudFormation template for InfraLens tests.",
  "Resources": {
    "GoodApplicationRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "lambda.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "Policies": [
          {
            "PolicyName": "LeastPrivilegeInlinePolicy",
            "PolicyDocument": {
              "Version": "2012-10-17",
              "Statement": [
                {
                  "Effect": "Allow",
                  "Action": [
                    "logs:CreateLogStream",
                    "logs:PutLogEvents"
                  ],
                  "Resource": {
                    "Fn::Sub": "arn:aws:logs:${AWS::Region}:${AWS::AccountId}:log-group:/aws/lambda/infralens-good-function:*"
                  }
                },
                {
                  "Effect": "Allow",
                  "Action": "sqs:SendMessage",
                  "Resource": {
                    "Fn::GetAtt": [
                      "GoodQueue",
                      "Arn"
                    ]
                  }
                }
              ]
            }
          }
        ]
      }
    },
    "GoodDeadLetterQueue": {
      "Type": "AWS::SQS::Queue",
      "Properties": {
        "QueueName": "infralens-good-dlq"
      }
    },
    "GoodQueue": {
      "Type": "AWS::SQS::Queue",
      "Properties": {
        "QueueName": "infralens-good-queue",
        "RedrivePolicy": {
          "deadLetterTargetArn": {
            "Fn::GetAtt": [
              "GoodDeadLetterQueue",
              "Arn"
            ]
          },
          "maxReceiveCount": 5
        }
      }
    },
    "GoodTable": {
      "Type": "AWS::DynamoDB::Table",
      "Properties": {
        "TableName": "infralens-good-table",
        "BillingMode": "PAY_PER_REQUEST",
        "AttributeDefinitions": [
          {
            "AttributeName": "id",
            "AttributeType": "S"
          }
        ],
        "KeySchema": [
          {
            "AttributeName": "id",
            "KeyType": "HASH"
          }
        ],
        "PointInTimeRecoverySpecification": {
          "PointInTimeRecoveryEnabled": true
        }
      }
    },
    "GoodFunction": {
      "Type": "AWS::Lambda::Function",
      "Properties": {
        "FunctionName": "infralens-good-function",
        "Runtime": "nodejs20.x",
        "Handler": "index.handler",
        "Role": {
          "Fn::GetAtt": [
            "GoodApplicationRole",
            "Arn"
          ]
        },
        "Timeout": 10,
        "Code": {
          "ZipFile": "exports.handler = async () => ({ statusCode: 200 });"
        }
      }
    },
    "GoodFunctionLogGroup": {
      "Type": "AWS::Logs::LogGroup",
      "Properties": {
        "LogGroupName": "/aws/lambda/infralens-good-function",
        "RetentionInDays": 14
      }
    }
  }
}
